diff --git a/crates/world-agent/tests/landlock_exec_fail_closed.rs b/crates/world-agent/tests/landlock_exec_fail_closed.rs
new file mode 100644
index 0000000000000000000000000000000000000000..854ad84c95bddf81f5ac778854c100407748c386
