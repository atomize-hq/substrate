use std::process::Command;

use tempfile::tempdir;
use world_agent::internal_exec::LANDLOCK_EXEC_ARG;

fn landlock_supported() -> bool {
    world::landlock::detect_support().supported
}

fn world_agent_bin() -> String {
    std::env::var("CARGO_BIN_EXE_world-agent").expect("CARGO_BIN_EXE_world-agent is set for tests")
}

#[test]
fn landlock_exec_full_isolation_requires_mountinfo_match_fails_closed() {
    if !landlock_supported() {
        eprintln!("skipping landlock exec fail-closed test: landlock unsupported");
        return;
    }

    let tmp = tempdir().expect("tempdir");
    let marker = tmp.path().join("inner-command-ran.txt");
    let mountpoint = format!("/__substrate_missing_mountpoint_{}", uuid::Uuid::now_v7());

    let output = Command::new(world_agent_bin())
        .arg(LANDLOCK_EXEC_ARG)
        .env("SUBSTRATE_WORLD_FS_ISOLATION", "full")
        .env("SUBSTRATE_MOUNT_PROJECT_DIR", &mountpoint)
        .env("SUBSTRATE_MOUNT_CWD", "/tmp")
        .env("SUBSTRATE_INNER_CMD", r#"echo ran > "$SUBSTRATE_TEST_MARKER""#)
        .env("SUBSTRATE_TEST_MARKER", marker.display().to_string())
        // Ensure Landlock will be applied for this exec (non-empty allowlists).
        .env("SUBSTRATE_WORLD_FS_LANDLOCK_WRITE_ALLOWLIST", "/tmp\n")
        .output()
        .expect("run world-agent landlock exec wrapper");

    let exit = output.status.code().unwrap_or(-1);
    let stderr = String::from_utf8_lossy(&output.stderr);

    assert_eq!(
        exit, 4,
        "expected fail-closed exit=4, got exit={exit} stderr={stderr:?}"
    );
    assert!(
        !marker.exists(),
        "inner command executed unexpectedly (marker exists: {})",
        marker.display()
    );
    assert!(
        stderr.contains(&mountpoint),
        "expected mountpoint in error message, got stderr={stderr:?}"
    );
    assert!(
        stderr.contains("/proc/self/mountinfo"),
        "expected /proc/self/mountinfo hint in error message, got stderr={stderr:?}"
    );
}

