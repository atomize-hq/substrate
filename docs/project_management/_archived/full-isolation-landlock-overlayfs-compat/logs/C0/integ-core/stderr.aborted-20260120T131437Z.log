REPO_ROOT="$(git rev-parse --show-toplevel)"
SUB="$REPO_ROOT/target/debug/substrate"
TMP_HOME="$(mktemp -d)"
TMP_WS="$(mktemp -d)"
cleanup(){ rm -rf "$TMP_HOME" "$TMP_WS"; }
trap cleanup EXIT
export SUBSTRATE_HOME="$TMP_HOME"
export HOME="$TMP_HOME"

"$SUB" config global init --force >/dev/null
"$SUB" policy global init --force >/dev/null
"$SUB" config global set policy.mode=enforce >/dev/null
"$SUB" config global set world.enabled=true >/dev/null
"$SUB" config global set world.anchor_mode=follow-cwd >/dev/null

"$SUB" workspace init "$TMP_WS" >/dev/null
cd "$TMP_WS"
mkdir -p writable
"$SUB" policy workspace init --force >/dev/null
"$SUB" policy workspace set '"\\
  world_fs.mode=writable \\
  world_fs.isolation=full \\
  world_fs.require_world=true \\
  world_fs.write_allowlist='[\"./writable/*\"]' \\
  >/dev/null

