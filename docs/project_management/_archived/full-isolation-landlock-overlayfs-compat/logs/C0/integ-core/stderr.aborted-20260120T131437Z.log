# Start a worktree-built world-agent behind a user-writable socket via socket activation.
# systemd-socket-activate will start the child on first connection and keep running.
systemd-socket-activate -l "$SOCK" ./target/debug/world-agent >/tmp/substrate-smoke.$$.log 2>&1 &
ACT_PID=$!
cleanup() {
  kill "$ACT_PID" 2>/dev/null || true
  rm -f "$SOCK" 2>/dev/null || true
  rm -f /tmp/substrate-smoke.$$.log 2>/dev/null || true
}
trap cleanup EXIT

export PATH="$PWD/target/debug:$PATH"
export SUBSTRATE_WORLD_SOCKET="$SOCK"

