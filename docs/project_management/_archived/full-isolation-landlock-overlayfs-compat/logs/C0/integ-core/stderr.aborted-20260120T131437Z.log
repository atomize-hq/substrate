+    std::env::remove_var("SUBSTRATE_WORLD");
+    std::env::remove_var("SUBSTRATE_WORLD_ENABLED");
+    std::env::remove_var("SUBSTRATE_NO_SHIMS");
+
+    let cli = Cli::parse_from(["substrate", "-c", "echo one\\necho two"]);
