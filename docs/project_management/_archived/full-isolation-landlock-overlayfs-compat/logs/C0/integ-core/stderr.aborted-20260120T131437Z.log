/bin/bash -lc 'set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
SUB="$REPO_ROOT/target/debug/substrate"
HELPER="$REPO_ROOT/target/debug/world-agent"

TMP_HOME="$(mktemp -d)"
TMP_WS="$(mktemp -d)"
cleanup(){ rm -rf "$TMP_HOME" "$TMP_WS"; }
trap cleanup EXIT
export SUBSTRATE_HOME="$TMP_HOME"
export HOME="$TMP_HOME"
export SUBSTRATE_LANDLOCK_HELPER_SRC="$HELPER"

"$SUB" config global init --force >/dev/null
