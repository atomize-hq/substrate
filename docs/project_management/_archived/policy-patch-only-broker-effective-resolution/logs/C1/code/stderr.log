new file mode 100644
index 0000000000000000000000000000000000000000..fd0bd21766021eef8929aed11bb9308bf714d4b9
--- /dev/null
+++ b/crates/broker/src/errors.rs
@@ -0,0 +1,37 @@
+use anyhow::Error;
+use std::error::Error as StdError;
+use std::fmt;
+
+#[derive(Debug)]
+pub struct PolicyResolutionError {
+    source: Error,
+}
+
+impl PolicyResolutionError {
+    pub(crate) fn new(source: Error) -> Self {
+        Self { source }
+    }
+}
+
+impl fmt::Display for PolicyResolutionError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        write!(f, "{}", self.source)
+    }
+}
+
+impl StdError for PolicyResolutionError {
+    fn source(&self) -> Option<&(dyn StdError + 'static)> {
+        Some(self.source.as_ref())
+    }
+}
+
+pub fn is_policy_resolution_error(err: &Error) -> bool {
+    err.chain().any(|cause| cause.is::<PolicyResolutionError>())
+}
+
+pub(crate) fn policy_resolution_error(err: Error) -> Error {
+    if is_policy_resolution_error(&err) {
+        return err;
+    }
+    Error::new(PolicyResolutionError::new(err))
+}
