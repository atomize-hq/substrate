+#[test]
+#[serial]
+fn test_shim_fails_closed_on_invalid_workspace_policy_patch() -> Result<()> {
+    let temp = TempDir::new()?;
+    let workspace_root = temp.path().join("workspace");
+    let workspace_substrate_dir = workspace_root.join(".substrate");
+    fs::create_dir_all(&workspace_substrate_dir)?;
+    fs::write(
+        workspace_substrate_dir.join("workspace.yaml"),
+        "schema_version: 1\n",
+    )?;
+    fs::write(workspace_substrate_dir.join("policy.yaml"), "world_fs: [\n")?;
+
+    let substrate_home_root = temp.path().join("home");
+    let substrate_home = substrate_home_root.join(".substrate");
+    fs::create_dir_all(&substrate_home)?;
+
+    let marker_path = temp.path().join("shim-policy-invalid-marker");
+
+    let shim_dir = temp.path().join("shims");
+    let bin_dir = temp.path().join("bin");
+    fs::create_dir_all(&shim_dir)?;
+    fs::create_dir_all(&bin_dir)?;
+
+    let test_cmd = "testcmd";
+    let real_binary = bin_dir.join(test_cmd);
+    fs::write(
+        &real_binary,
+        format!(
+            "#!/bin/bash\nset -euo pipefail\necho executed > \"{}\"\n",
+            marker_path.display()
+        ),
+    )?;
+
+    #[cfg(unix)]
+    {
+        use std::os::unix::fs::PermissionsExt;
+        let mut perms = fs::metadata(&real_binary)?.permissions();
+        perms.set_mode(0o755);
+        fs::set_permissions(&real_binary, perms)?;
+    }
+
+    let shim_binary_path = get_shim_binary_path();
+    let shim_binary = shim_dir.join(test_cmd);
+    fs::copy(shim_binary_path, &shim_binary)?;
+
+    #[cfg(unix)]
+    {
+        use std::os::unix::fs::PermissionsExt;
+        let mut perms = fs::metadata(&shim_binary)?.permissions();
+        perms.set_mode(0o755);
+        fs::set_permissions(&shim_binary, perms)?;
+    }
+
+    let shimmed_path = format!("{}:{}", shim_dir.display(), bin_dir.display());
+
+    let cwd = workspace_root.join("a");
+    fs::create_dir_all(&cwd)?;
+
+    let mut cmd = Command::new(&shim_binary);
+    cmd.arg("ignored")
+        .current_dir(&cwd)
+        .env("HOME", &substrate_home_root)
+        .env("USERPROFILE", &substrate_home_root)
+        .env("SUBSTRATE_HOME", &substrate_home)
+        .env("SHIM_ORIGINAL_PATH", bin_dir.to_string_lossy().as_ref())
+        .env("PATH", &shimmed_path)
+        .env_remove("SHIM_DEPTH")
+        .env_remove("SHIM_ACTIVE");
+    let output = run_with_retry(cmd)?;
+
+    assert_eq!(
+        output.status.code(),
+        Some(2),
+        "invalid workspace policy patch should exit 2: {output:?}"
+    );
+    assert!(
+        !marker_path.exists(),
+        "real binary should not be executed when policy resolution fails"
+    );
+
+    Ok(())
+}
