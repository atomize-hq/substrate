-name: Default Policy
 world_fs:
-  mode: writable            # writable | read_only
-  isolation: workspace      # workspace | full
-  require_world: false      # true = no host fallback when world is unavailable
-  read_allowlist:
-    - "*"                   # required, must be non-empty
-  write_allowlist: []       # required, can be empty
