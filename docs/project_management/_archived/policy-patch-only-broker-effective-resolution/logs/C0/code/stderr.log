+const WORKSPACE_MARKER_FILENAME: &str = "workspace.yaml";
+const WORKSPACE_DISABLED_FILENAME: &str = "workspace.disabled";
+const WORKSPACE_POLICY_FILENAME: &str = "policy.yaml";
