+            info!("Loaded workspace policy patch from {:?}", path);
+            loaded_any = true;
+        }
+        if let Some(path) = sources.global_patch_path {
+            info!("Loaded global policy patch from {:?}", path);
+            loaded_any = true;
+        }
+        if !loaded_any {
             info!("Loaded built-in default policy");
         }
         Ok(())
