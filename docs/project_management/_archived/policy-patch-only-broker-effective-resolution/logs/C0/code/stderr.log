+    let (max_memory_mb, max_memory_mb_src) = resolve_replace_opt(
+        effective.limits.max_memory_mb,
+        global_patch.limits.max_memory_mb,
+        workspace_patch.and_then(|p| p.limits.max_memory_mb),
