+        global_patch.cmd_isolated.clone(),
+        workspace_patch.and_then(|p| p.cmd_isolated.clone()),
+        workspace_enabled,
+    );
+    effective.cmd_isolated = cmd_isolated;
+    if let Some(keys) = &mut explain_keys {
+        keys.insert(
