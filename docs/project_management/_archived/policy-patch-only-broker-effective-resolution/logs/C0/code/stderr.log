+        );
+    }
+
+    let (cmd_isolated, cmd_isolated_src) = resolve_replace(
+        effective.cmd_isolated.clone(),
+        global_patch.cmd_isolated.clone(),
+        workspace_patch.and_then(|p| p.cmd_isolated.clone()),
+        workspace_enabled,
