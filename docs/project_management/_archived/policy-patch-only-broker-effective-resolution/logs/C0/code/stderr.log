+    #[serde(skip_serializing_if = "Option::is_none")]
+    pub max_egress_bytes: Option<u64>,
+}
+
+impl ResourceLimitsPatch {
+    fn is_empty(&self) -> bool {
+        self.max_memory_mb.is_none()
