+    effective.require_approval = require_approval;
+    if let Some(keys) = &mut explain_keys {
+        keys.insert(
+            "require_approval".to_string(),
+            PolicyExplainKey {
+                merge_strategy: "replace".to_string(),
+                sources: vec![explain_source(
+                    require_approval_src,
