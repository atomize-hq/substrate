+    let (max_egress_bytes, max_egress_bytes_src) = resolve_replace_opt(
+        effective.limits.max_egress_bytes,
+        global_patch.limits.max_egress_bytes,
+        workspace_patch.and_then(|p| p.limits.max_egress_bytes),
