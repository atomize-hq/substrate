+        cmd.env_remove("SUBSTRATE_WORLD");
+        cmd.env_remove("SUBSTRATE_WORLD_ENABLED");
+        cmd.env("SUBSTRATE_OVERRIDE_WORLD", "disabled");
+        cmd.env_remove("SUBSTRATE_WORLD_ID");
+        cmd
