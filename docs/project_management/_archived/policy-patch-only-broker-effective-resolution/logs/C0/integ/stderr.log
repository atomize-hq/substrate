fn dedupe_ordered_set_in_place(items: &mut Vec<String>) {
    let mut out: Vec<String> = Vec::with_capacity(items.len());
    for item in items.drain(..) {
        if !out.iter().any(|existing| existing == &item) {
            out.push(item);
        }
    }
    *items = out;
}

