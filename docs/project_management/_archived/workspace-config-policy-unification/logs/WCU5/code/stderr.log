+            Ok(raw) => Some((parse_policy_patch_yaml(&path, &raw)?, path)),
+            Err(err) if err.kind() == io::ErrorKind::NotFound => None,
+            Err(err) => return Err(anyhow!("failed to read {}: {err}", path.display())),
+        }
+    } else {
+        None
