+        workspace_path: Option<&Path>,
+    ) -> PolicyExplainSource {
+        match source {
+            ReplaceSource::WorkspacePatch => PolicyExplainSource {
+                layer: "workspace_patch".to_string(),
+                path: workspace_path.map(|p| p.display().to_string()),
