+pub(crate) fn reset_policy_patch_keys(patch: &mut PolicyPatch, keys: &[String]) -> Result<bool> {
+    if keys.is_empty() {
+        let was_empty = patch.is_empty();
+        *patch = PolicyPatch::default();
+        return Ok(!was_empty);
+    }
+
+    let mut changed = false;
+    for key in keys {
+        changed |= reset_policy_patch_key(patch, key)?;
+    }
+    Ok(changed)
+}
