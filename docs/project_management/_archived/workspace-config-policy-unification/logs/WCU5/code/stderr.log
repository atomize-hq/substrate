     let mut tmp = NamedTempFile::new_in(parent)
         .with_context(|| format!("failed to create temp file near {}", path.display()))?;
-    tmp.write_all(bytes)
+    tmp.write_all(out.as_bytes())
         .with_context(|| format!("failed to write {}", path.display()))?;
