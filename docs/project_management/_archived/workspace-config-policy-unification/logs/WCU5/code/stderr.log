+fn print_patch(patch: &SubstrateConfigPatch, json: bool) -> Result<()> {
+    if json {
+        println!(
+            "{}",
+            serde_json::to_string(patch).context("failed to serialize JSON")?
+        );
+        return Ok(());
+    }
+    println!(
+        "{}",
+        serde_yaml::to_string(patch).context("failed to serialize YAML")?
+    );
+    Ok(())
+}
