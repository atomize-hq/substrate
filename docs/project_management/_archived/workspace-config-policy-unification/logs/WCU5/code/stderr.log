+        body = rest.to_string();
+    }
+
+    let mut out = String::new();
+    out.push_str(header);
+    if !out.is_empty() && !out.ends_with('\n') {
+        out.push('\n');
+    }
+    out.push_str(&body);
+    if !out.ends_with('\n') {
+        out.push('\n');
+    }
+
