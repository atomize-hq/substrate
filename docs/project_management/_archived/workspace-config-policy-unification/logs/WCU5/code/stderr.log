+        if workspace_enabled {
+            if let Some(v) = workspace {
+                return (v, ReplaceSource::WorkspacePatch);
+            }
+        }
+        if let Some(v) = global {
+            return (v, ReplaceSource::GlobalPatch);
+        }
+        (default, ReplaceSource::Default)
