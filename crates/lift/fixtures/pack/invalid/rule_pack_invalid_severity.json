{
  "$schema": "https://schemas.substrate.dev/lift/pack/rule_pack.v1.json",
  "kind": "rule_pack",
  "version": 1,
  "id": "acme/bad-severity",
  "name": "Bad severity",
  "rules": [
    {
      "id": "architecture.bad_severity",
      "severity": "critical",
      "query": {
        "pack": "file:queries/rust_core.json",
